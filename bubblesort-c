#include<stdio.h>
#include<stdlib.h>
#include<time.h>


void bubbleSort(int a[] , int n){
    int temp;
    for(int i=0; i<=n-2; i++)
    {
        for(int j=0; j<=n-2-i; j++)
        {
            if (a[j+1]<= a[j])
            {
                temp=a[j];
                a[j]=a[j+1];
                a[j+1]=temp;
            }
        }
    }
}

//function to generate randon numbers between 0 - 9999
void generateRandomNumbers(int a[],int n){
    for(int i=0;i<n;i++){
        a[i]=rand()%10000;
    }
}

