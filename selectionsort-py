import random
import time
import matplotlib.pyplot as plt
def generate_ran(n):
    return [random.randint(0,9999) for _ in range(n)]

def s_sort(a):
    n = len(a)

    for i in range(n-1):
        min = i

        for j in range(i+1, n):
            if a[j] < a[min]:
                min = j

        a[i], a[min] = a[min], a[i]
sizes=[]
actual_time=[]
theoretical_time=[]
with open('s_time.txt','w') as fp:
    for n in range(100, 10000, 400):
        arr=generate_ran(n)
        start=time.perf_counter() #records high precision time stamp 
        s_sort(arr)
        end=time.perf_counter()
        t_t=end-start
        th_t=(n*n) * 1e-8
        fp.write(f'{n}{t_t}{theoretical_time}\n')
        sizes.append(n)
        actual_time.append(t_t)
        theoretical_time.append(th_t)
    plt.figure(figsize=(10,6))
    plt.plot(sizes, actual_time, marker = 'o', label= 'Actual time' )
    plt.plot(sizes, theoretical_time, linewidth=2, label= "theoritical time")
    plt.title("Selection sort efficiency in py")
    plt.xlabel("Input size")
    plt.ylabel("time (seconds)")
    plt.grid(True)
    plt.legend()
    plt.savefig('s_sort_effieciency_python.png')
    plt.show()
